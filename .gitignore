# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# logs
logs/*.log

# doc artifacts (screenshots, traces — point-in-time verification, not reference)
docs/**/*.png
!docs/visual-audit/phase-*/
!docs/visual-audit/phase-*/*.png
docs/**/*.json
!docs/audits/phase-*/*.json
claude-handover/images/

# AI tool config directories (from various coding assistants)
.adal/
.agents/
.augment/
.bob/
.codebuddy/
.commandcode/
.continue/
.cortex/
.crush/
.factory/
.goose/
.iflow/
.junie/
.kilocode/
.kiro/
.kode/
.mcpjam/
.mux/
.neovate/
.openhands/
.pi/
.pochi/
.qoder/
.qwen/
.roo/
.trae/
.vibe/
.windsurf/
.zencoder/

# wrangler local state
.wrangler/state/

# skills (AI tool skills, not project code)
/skills/
skills-lock.json

# confidential — NDA-protected private datasets used for engine calibration.
# Place private materials under one of these directories. Engine references
# constants by value, not by source file, so paths inside never appear in
# committed code.
docs/_private/
docs/_clients/
